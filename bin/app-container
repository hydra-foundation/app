#!/usr/bin/env bash
# Run a command in the php container from the app dir, or open a shell with no args.
#   ./bin/app-container                      # bash shell
#   ./bin/app-container composer install     # run a command
#   ./bin/app-container vendor/bin/phpunit   # run the tests
#
# The repo root is mounted at /var/www/html, so the app lives in
# /var/www/html/app — commands run there so composer.json/vendor resolve.
set -euo pipefail

cd "$(dirname "$0")/.."

workdir=/var/www/html/app

if [ $# -eq 0 ]; then
    exec docker compose exec -it -w "$workdir" php bash
else
    exec docker compose exec -it -w "$workdir" php "$@"
fi
