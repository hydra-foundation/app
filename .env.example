# APPLICATION
APP_NAME=Hydra
APP_URL=http://hydra.localhost
APP_DEBUG=true                    # Set to false in production
APP_TIMEZONE=UTC
APP_KEY=                          # Generate with: php bin/console key:generate
FORCE_HTTPS=false                 # Set to true in production to force https + HSTS

# AUTH
# bcrypt work factor used by Hydra\Auth\NativeHasher. Higher is slower and more
# resistant to brute force; raise it as high as your hardware tolerates in
# production. Tests and CI use a low cost so hashing stays fast. Valid range 4-31.
AUTH_HASH_COST=12

# ROUTING
# Compile controller #[Route] attributes to bootstrap/cache/routes.php and load
# them from there instead of reflecting on every request. A production-only
# optimisation: leave it false in development so route edits take effect at
# once. When true, build the cache with `php bin/console route:cache` (rebuild
# with the same command, drop it with route:cache:clear). The web path only
# reads the cache — `route:cache` is the sole writer.
ROUTE_CACHE=false

# LOGGING
# php://stderr surfaces logs via `docker logs`. Use an absolute,
# writable file path for a file sink. An unwritable path falls back to stderr.
LOG_PATH=php://stderr

# DOCKER
# Host port the dev stack publishes nginx on (http://localhost:<APP_PORT>).
APP_PORT=8080
# Hostname for the optional Traefik proxy (docker-compose.local.yml):
# http://<DEV_HOSTNAME>.localhost. Subdomains route too (*.localhost).
DEV_HOSTNAME=hydra

# DATABASE
DB_DRIVER=mariadb
DB_NAME=hydra
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_HOST=db                        # "db" inside Docker, "localhost" on the host
DB_PORT=3306
DB_CHARSET=utf8mb4

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                   # Set a password in production
REDIS_DATABASE=0
REDIS_PREFIX=hydra:
