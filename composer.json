{
    "name": "hydra/app",
    "description": "Hydra PHP framework application skeleton",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } },
        { "type": "path", "url": "../http", "options": { "symlink": true } },
        { "type": "path", "url": "../validation", "options": { "symlink": true } },
        { "type": "path", "url": "../session", "options": { "symlink": true } },
        { "type": "path", "url": "../csrf", "options": { "symlink": true } },
        { "type": "path", "url": "../auth", "options": { "symlink": true } },
        { "type": "path", "url": "../authorization", "options": { "symlink": true } },
        { "type": "path", "url": "../log", "options": { "symlink": true } },
        { "type": "path", "url": "../database", "options": { "symlink": true } },
        { "type": "path", "url": "../view", "options": { "symlink": true } },
        { "type": "path", "url": "../nyholm", "options": { "symlink": true } },
        { "type": "path", "url": "../console", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydra/core": "*",
        "hydra/http": "*",
        "hydra/validation": "*",
        "hydra/session": "*",
        "hydra/csrf": "*",
        "hydra/auth": "*",
        "hydra/authorization": "*",
        "hydra/log": "*",
        "hydra/database": "*",
        "hydra/view": "*",
        "hydra/nyholm": "*",
        "hydra/console": "*",
        "php-di/php-di": "^7.0",
        "nyholm/psr7": "^1.8",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public/"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
